#!/bin/sh
# Determinagents shim — wraps git operations and host-tool installation
set -eu

# Resolve DETERMINAGENTS_HOME:
# 1. Environment variable
# 2. Relative to script (if run from a clone)
# 3. Default path
if [ -n "${DETERMINAGENTS_HOME:-}" ]; then
  : # already set
elif [ -f "$(dirname "$0")/../INVOCATIONS.md" ]; then
  DETERMINAGENTS_HOME=$(cd "$(dirname "$0")/.." && pwd)
else
  DETERMINAGENTS_HOME="$HOME/.determinagents"
fi

if [ ! -d "$DETERMINAGENTS_HOME/.git" ]; then
  echo "error: determinagents not installed at $DETERMINAGENTS_HOME" >&2
  echo "  run the installer:" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/iansherr/determinagents/main/install.sh | sh" >&2
  exit 1
fi

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

  version|--version|-v)
    cd "$DETERMINAGENTS_HOME"
    SHA=$(git rev-parse --short HEAD)
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    DATE=$(git log -1 --format=%cd --date=short)
    SUBJECT=$(git log -1 --format=%s)
    echo "determinagents $SHA  ($BRANCH, $DATE)"
    echo "  $SUBJECT"
    echo "  installed at: $DETERMINAGENTS_HOME"
    ;;

  path)
    echo "$DETERMINAGENTS_HOME"
    ;;

  update)
    cd "$DETERMINAGENTS_HOME"
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    OLD_SHA=$(git rev-parse HEAD)
    echo "fetching origin/$BRANCH..."
    git fetch --quiet origin "$BRANCH"
    NEW_SHA=$(git rev-parse "origin/$BRANCH")

    if [ "$OLD_SHA" = "$NEW_SHA" ]; then
      echo "already up to date ($(git rev-parse --short HEAD))"
      exit 0
    fi

    echo ""
    echo "Changes since current ($(git rev-parse --short HEAD)):"
    echo "---"
    git log --oneline "$OLD_SHA..$NEW_SHA"
    echo "---"
    echo ""
    git diff --stat "$OLD_SHA..$NEW_SHA"
    echo ""

    printf "Apply update? [y/N] "
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES)
        git pull --ff-only --quiet origin "$BRANCH"
        echo "updated to $(git rev-parse --short HEAD)"
        echo ""
        echo "if you previously ran 'determinagents materialize', re-run it"
        echo "to regenerate any changed slash commands."
        ;;
      *)
        echo "skipped"
        ;;
    esac
    ;;

  materialize|install-commands)
    cat <<MSG
To complete materialization, hand this prompt to a coding agent in your tool
(Claude Code, Gemini, Cursor, etc.):

---
Read ${DETERMINAGENTS_HOME}/INSTALL.md and install the determinagents
library for this host tool.

Identify the host tool from context, pick the appropriate target convention,
and generate the install files. Start by creating the primary
\`/determinagents\` hub command that lists all available audits. Then, ask
if I want the full suite of individual slash commands or just the hub.

Show the plan before writing files.
---

The agent does the actual file generation. This shim cannot directly write
host-tool files because they require host-tool context (frontmatter
conventions, command vs. skill choice) that an agent decides better than a
shell script.
MSG
    ;;

  uninstall)
    printf 'Remove %s? [y/N] ' "$DETERMINAGENTS_HOME"
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES)
        rm -rf "$DETERMINAGENTS_HOME"
        echo "removed $DETERMINAGENTS_HOME"
        echo "note: any host-tool slash commands generated by 'materialize' are not removed"
        echo "  (point an agent at the generated files to clean those up)"
        ;;
      *) echo "skipped" ;;
    esac
    ;;

  help|--help|-h|"")
    cat <<HELP
determinagents — universal, self-discovering audit prompts for coding agents

usage: determinagents <command>

  version              show installed version (SHA, branch, date)
  path                 print install path
  update               check for updates and apply with confirmation
  materialize [host]   instructions to install slash commands for host tool
                       (host: claude-code | gemini | cursor; auto-detected if omitted)
  uninstall            remove the library
  help                 this message

env:
  DETERMINAGENTS_HOME  install path (default: ~/.determinagents)
  DETERMINAGENTS_BIN   shim install path (default: ~/.local/bin)

docs:
  $DETERMINAGENTS_HOME/README.md         overview
  $DETERMINAGENTS_HOME/INVOCATIONS.md    paste-ready prompts
  $DETERMINAGENTS_HOME/INSTALL.md        host-tool install spec
HELP
    ;;

  *)
    echo "unknown command: $cmd" >&2
    echo "run 'determinagents help' for usage" >&2
    exit 1
    ;;
esac
