#!/bin/sh
# DeterminAgents shim — wraps git operations and host-tool installation
set -eu

# Subcommand list lives in three places that must stay in sync: the `help`
# heredoc, the `doctor`/`completions` outputs, and the bash/zsh/fish
# completion bodies. The completion scripts run in a separate shell after
# being eval'd, so a runtime variable wouldn't reach them — duplication is
# the honest shape here.

# This line is replaced by the installer. Do not edit manually.
DETERMINAGENTS_BAKED_HOME=""

# Resolve DETERMINAGENTS_HOME:
# 1. Environment variable (manual override)
# 2. Baked path (set during last install — ensures we remember the user's choice)
# 3. Relative to script (if run from a clone — priority for developers)
# 4. Default path
if [ -n "${DETERMINAGENTS_HOME:-}" ]; then
  RESOLVED_VIA="env"
elif [ -n "$DETERMINAGENTS_BAKED_HOME" ]; then
  DETERMINAGENTS_HOME="$DETERMINAGENTS_BAKED_HOME"
  RESOLVED_VIA="baked"
elif [ -f "$(dirname "$0")/../INVOCATIONS.md" ] && ([ -d "$(dirname "$0")/../.git" ] || [ -d "$(dirname "$0")/../.sisyphus" ]); then
  DETERMINAGENTS_HOME=$(cd "$(dirname "$0")/.." && pwd)
  RESOLVED_VIA="relative"
else
  DETERMINAGENTS_HOME="$HOME/.determinagents"
  RESOLVED_VIA="default"
fi

if [ ! -d "$DETERMINAGENTS_HOME/audits" ]; then
  echo "error: determinagents library not found at $DETERMINAGENTS_HOME" >&2
  echo "  (resolved via $RESOLVED_VIA)" >&2
  [ -n "$DETERMINAGENTS_BAKED_HOME" ] && [ "$DETERMINAGENTS_HOME" != "$DETERMINAGENTS_BAKED_HOME" ] && echo "  (baked path was: $DETERMINAGENTS_BAKED_HOME)" >&2
  echo "" >&2
  echo "  run the installer to fix your paths:" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/iansherr/determinagents/main/install.sh | sh" >&2
  exit 1
fi

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

  version|--version|-v)
    cd "$DETERMINAGENTS_HOME"
    SHA=$(git rev-parse --short HEAD)
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    DATE=$(git log -1 --format=%cd --date=short)
    SUBJECT=$(git log -1 --format=%s)
    echo "determinagents $SHA  ($BRANCH, $DATE)"
    echo "  $SUBJECT"
    echo "  library: $DETERMINAGENTS_HOME ($RESOLVED_VIA)"
    ;;

  path)
    echo "$DETERMINAGENTS_HOME"
    ;;

  update)
    cd "$DETERMINAGENTS_HOME"
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    OLD_SHA=$(git rev-parse HEAD)
    echo "fetching origin/$BRANCH..."
    git fetch --quiet origin "$BRANCH"
    NEW_SHA=$(git rev-parse "origin/$BRANCH")

    if [ "$OLD_SHA" = "$NEW_SHA" ]; then
      echo "already up to date ($(git rev-parse --short HEAD))"
      exit 0
    fi

    echo ""
    echo "Changes since current ($(git rev-parse --short HEAD)):"
    echo "---"
    git log --oneline "$OLD_SHA..$NEW_SHA"
    echo "---"
    echo ""
    git diff --stat "$OLD_SHA..$NEW_SHA"
    echo ""

    printf "Apply update? [y/N] "
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES)
        git pull --ff-only --quiet origin "$BRANCH"
        echo "updated to $(git rev-parse --short HEAD)"
        echo ""
        echo "if you previously ran 'determinagents materialize', re-run it"
        echo "to regenerate any changed slash commands."
        ;;
      *)
        echo "skipped"
        ;;
    esac
    ;;

  materialize|install-commands)
    cat <<MSG
To complete materialization, hand this prompt to a coding agent in your tool
(Claude Code, Gemini, Cursor, etc.):

---
Read ${DETERMINAGENTS_HOME}/INSTALL.md and install the DeterminAgents
library for this host tool.

Identify the host tool from context, pick the appropriate target convention,
and generate the install files. Start by creating the primary
\`/determinagents\` command and use it as both hub and router.

**Discovery & Autocomplete Strategy:**
- **Claude Code**: Use \`argument-hint\` in the single \`/determinagents\`
  command for discovery.
- **Gemini CLI**: Use **subdirectory namespacing** (\`/determinagents:<name>\`)
  because its custom commands don't yet support argument autocomplete.
- **Cursor**: Use agent-requested MDC rules.

If DeterminAgents commands already exist in the host tool, treat this as a
re-materialize. Compare the existing files against the new library path and
the latest \`INVOCATIONS.md\`.

- If a file lacks the \`generated-by\` marker or points to a different
  library path: treat it as a 'legacy' or 'hand-edited' file and PROMPT
  ME before overwriting.
- If a file has the marker and correct path but the content differs from
  the new source: report the change and prompt me.
- If everything matches (path, marker, content): skip it silently or
  report as "unchanged."

Show the plan (what will be created, updated, or migrated) and wait for
my approval before writing files.
---

The agent does the actual file generation. This shim cannot directly write
host-tool files because they require host-tool context (frontmatter
conventions, command vs. skill choice) that an agent decides better than a
shell script.

Important boundary: this CLI does not execute audits. Use your host-tool
slash command flow (\`/determinagents\` or \`/determinagents <behavior>\`)
to run audits.
MSG
    ;;

  uninstall)
    printf 'Remove %s? [y/N] ' "$DETERMINAGENTS_HOME"
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES)
        REMOVED_HOME="$DETERMINAGENTS_HOME"
        rm -rf "$DETERMINAGENTS_HOME"
        SHIM_PATH=$(command -v determinagents 2>/dev/null || echo "${DETERMINAGENTS_BIN:-$HOME/.local/bin}/determinagents")
        cat <<UNINSTALL_MSG
removed $REMOVED_HOME

Slash commands generated by 'determinagents materialize' are NOT
removed automatically — they live inside your host tool's command
directory (e.g. \$HOME/.claude/commands/, \$HOME/.gemini/commands/).

To clean those up, paste this prompt into the same host tool that
originally installed them:

---
Remove every DeterminAgents slash command from this host tool.
Look in the host tool's command directory (e.g. \$HOME/.claude/commands/,
\$HOME/.gemini/commands/, .cursor/rules/) and identify files generated by
the DeterminAgents library — typically by a header comment naming
INSTALL.md as the source, or a body that references
\$DETERMINAGENTS_HOME or 'Read .../audits/<name>.md'.
Show the list and wait for my approval before deleting anything.
Do NOT match by filename alone — user files may share naming.
---

Also remove the shim itself if no longer needed:
  rm $SHIM_PATH
UNINSTALL_MSG
        ;;
      *) echo "skipped" ;;
    esac
    ;;

  doctor)
    # Read-only health check. Exit 0 if all checks pass or only warn,
    # exit 1 if any fail. Prints one line per check.
    FAIL=0
    ok()   { printf '  ok    %s\n' "$1"; }
    warn() { printf '  warn  %s\n' "$1"; }
    fail() { printf '  fail  %s\n' "$1"; FAIL=1; }

    echo "determinagents doctor"
    echo ""
    echo "library:"

    # 1. Library directory and resolution source
    if [ -d "$DETERMINAGENTS_HOME/audits" ]; then
      ok "library found at $DETERMINAGENTS_HOME ($RESOLVED_VIA)"
    else
      fail "library missing at $DETERMINAGENTS_HOME ($RESOLVED_VIA)"
    fi

    # 2. Git status
    if [ -d "$DETERMINAGENTS_HOME/.git" ]; then
      BRANCH=$(git -C "$DETERMINAGENTS_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
      SHA=$(git -C "$DETERMINAGENTS_HOME" rev-parse --short HEAD 2>/dev/null || echo "?")
      AGE_DAYS=$(( ( $(date +%s) - $(git -C "$DETERMINAGENTS_HOME" log -1 --format=%ct 2>/dev/null || echo 0) ) / 86400 ))
      if [ "$AGE_DAYS" -gt 60 ]; then
        warn "branch $BRANCH @ $SHA — last commit ${AGE_DAYS}d ago (run 'determinagents update')"
      else
        ok "branch $BRANCH @ $SHA — ${AGE_DAYS}d old"
      fi
      if [ -n "$(git -C "$DETERMINAGENTS_HOME" status --porcelain 2>/dev/null)" ]; then
        warn "working tree has local changes (will block 'determinagents update')"
      fi
    else
      warn "library is not a git checkout (automatic updates disabled)"
    fi

    echo ""
    echo "shim:"

    # 3. Shim resolution: where did `determinagents` we ran from come from?
    RUNNING_BIN="$0"
    PATH_BIN=$(command -v determinagents 2>/dev/null || echo "")

    if [ -n "$PATH_BIN" ]; then
      ok "shim on PATH: $PATH_BIN"
      # Check if the one we are running is the one on the PATH
      if [ "$(cd "$(dirname "$RUNNING_BIN")" && pwd)/$(basename "$RUNNING_BIN")" = "$(cd "$(dirname "$PATH_BIN")" && pwd)/$(basename "$PATH_BIN")" ]; then
        : # Running the one on the PATH, good.
      else
        warn "you are running $RUNNING_BIN but $PATH_BIN is first on your PATH"
      fi
    else
      warn "shim not on PATH (you ran by absolute path)"
    fi

    # 4. Consistency check
    if [ "$RESOLVED_VIA" = "relative" ]; then
      warn "running in-place from repository ($DETERMINAGENTS_HOME)"
    elif [ "$RESOLVED_VIA" = "env" ]; then
      if [ -n "$DETERMINAGENTS_BAKED_HOME" ] && [ "$DETERMINAGENTS_HOME" != "$DETERMINAGENTS_BAKED_HOME" ]; then
        warn "\$DETERMINAGENTS_HOME ($DETERMINAGENTS_HOME) overrides baked path ($DETERMINAGENTS_BAKED_HOME)"
      else
        ok "\$DETERMINAGENTS_HOME environment variable is set"
      fi
    elif [ "$RESOLVED_VIA" = "baked" ]; then
      ok "using baked path: $DETERMINAGENTS_HOME"
    fi

    echo ""
    echo "remote:"

    # 6. Remote reachable (5s timeout via git's own machinery; degrade gracefully)
    if git -C "$DETERMINAGENTS_HOME" ls-remote --exit-code --heads origin "$BRANCH" >/dev/null 2>&1; then
      ok "origin reachable"
      LOCAL=$(git -C "$DETERMINAGENTS_HOME" rev-parse HEAD)
      REMOTE=$(git -C "$DETERMINAGENTS_HOME" ls-remote origin "$BRANCH" 2>/dev/null | awk '{print $1}')
      if [ "$LOCAL" = "$REMOTE" ]; then
        ok "up to date with origin/$BRANCH"
      else
        warn "behind origin/$BRANCH — run 'determinagents update'"
      fi
    else
      warn "could not reach origin (offline?)"
    fi

    echo ""
    echo "completions:"

    # 7. Completion: detect parent shell and tell the user how to enable.
    #    We can't introspect the parent shell's loaded functions from a child
    #    process, so we just point them at the right command.
    PARENT_SHELL=$(basename "${SHELL:-unknown}")
    case "$PARENT_SHELL" in
      bash|zsh|fish)
        ok "shell detected: $PARENT_SHELL"
        echo "        enable: see 'determinagents completions $PARENT_SHELL'"
        ;;
      *)
        warn "shell '$PARENT_SHELL' — completions ship for bash/zsh/fish only"
        ;;
    esac

    echo ""
    if [ "$FAIL" -eq 0 ]; then
      echo "all checks passed"
      exit 0
    else
      echo "one or more checks failed"
      exit 1
    fi
    ;;

  completions)
    shell="${1:-}"
    case "$shell" in
      bash)
        cat <<'BASH'
# determinagents completion for bash
# enable: eval "$(determinagents completions bash)"
#   or:   determinagents completions bash > /etc/bash_completion.d/determinagents
_determinagents_complete() {
  local cur prev subs
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  subs="version path update materialize uninstall doctor completions help"
  if [ "$COMP_CWORD" -eq 1 ]; then
    COMPREPLY=( $(compgen -W "$subs" -- "$cur") )
  elif [ "$COMP_CWORD" -eq 2 ] && [ "$prev" = "completions" ]; then
    COMPREPLY=( $(compgen -W "bash zsh fish" -- "$cur") )
  fi
}
complete -F _determinagents_complete determinagents
BASH
        ;;
      zsh)
        cat <<'ZSH'
# determinagents completion for zsh
# enable: eval "$(determinagents completions zsh)"
#   or save to a file in $fpath named _determinagents and run `compinit`
_determinagents() {
  local -a subs shells
  subs=(
    'version:show installed version (SHA, branch, date)'
    'path:print install path'
    'update:check for updates and apply with confirmation'
    'materialize:instructions to install slash commands for host tool'
    'uninstall:remove the library'
    'doctor:run health checks'
    'completions:print shell completion script'
    'help:show help'
  )
  shells=(bash zsh fish)
  if (( CURRENT == 2 )); then
    _describe 'subcommand' subs
  elif (( CURRENT == 3 )) && [[ ${words[2]} == completions ]]; then
    _describe 'shell' shells
  fi
}
compdef _determinagents determinagents
ZSH
        ;;
      fish)
        cat <<'FISH'
# determinagents completion for fish
# enable: determinagents completions fish | source
#   or save to ~/.config/fish/completions/determinagents.fish
complete -c determinagents -f
complete -c determinagents -n __fish_use_subcommand -a version     -d 'show installed version'
complete -c determinagents -n __fish_use_subcommand -a path        -d 'print install path'
complete -c determinagents -n __fish_use_subcommand -a update      -d 'check for updates'
complete -c determinagents -n __fish_use_subcommand -a materialize -d 'install slash commands'
complete -c determinagents -n __fish_use_subcommand -a uninstall   -d 'remove the library'
complete -c determinagents -n __fish_use_subcommand -a doctor      -d 'run health checks'
complete -c determinagents -n __fish_use_subcommand -a completions -d 'print completion script'
complete -c determinagents -n __fish_use_subcommand -a help        -d 'show help'
complete -c determinagents -n '__fish_seen_subcommand_from completions' -a 'bash zsh fish'
FISH
        ;;
      "")
        cat >&2 <<USAGE
usage: determinagents completions <shell>
  shells: bash, zsh, fish

bash:  eval "\$(determinagents completions bash)"
zsh:   eval "\$(determinagents completions zsh)"
fish:  determinagents completions fish | source
USAGE
        exit 1
        ;;
      *)
        echo "error: unknown shell '$shell' (supported: bash, zsh, fish)" >&2
        exit 1
        ;;
    esac
    ;;

  help|--help|-h|"")
    cat <<HELP
determinagents — universal, self-discovering audit prompts for coding agents

boundary:
  this CLI does not execute audits.
  use host-tool slash commands: /determinagents or
  /determinagents <behavior> [flags].

usage: determinagents <command>

  version              show installed version (SHA, branch, date)
  path                 print library path
  update               check for updates and apply with confirmation
  materialize          instructions to install slash commands for your host
                       tool (the agent detects Claude Code / Gemini / Cursor /
                       etc. from its own context — same prompt for all)
  uninstall            remove the library
  doctor               run health checks (library, shim, remote, completions)
  completions <shell>  print shell completion script (bash, zsh, fish)
  help                 this message

env:
  DETERMINAGENTS_HOME  library path (default: ~/.determinagents)
  DETERMINAGENTS_BIN   shim install path (default: ~/.local/bin)

docs:
  $DETERMINAGENTS_HOME/README.md         overview
  $DETERMINAGENTS_HOME/INVOCATIONS.md    paste-ready prompts
  $DETERMINAGENTS_HOME/INSTALL.md        host-tool install spec
HELP
    ;;

  *)
    echo "unknown command: $cmd" >&2
    echo "note: audits run via /determinagents in your host tool, not this CLI" >&2
    echo "run 'determinagents help' for usage" >&2
    exit 1
    ;;
esac
